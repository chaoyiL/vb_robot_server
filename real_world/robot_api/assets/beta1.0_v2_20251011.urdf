<!-- 
     Last modified: Oct 11, 2025
     Notes (Billie)
        1. Fix the frame of xjc force sensor to make it the same with real hardware

     Last modified: Sep 1, 2025
     Notes (Muzhi): 
        1. Add vicon center frame

     Last modified: Aug 29, 2025
     Notes (Muzhi): 
        1. Change joint limits within [-pi, pi] as the encoder is single-round
        2. Update joint limits of waist and head

     Last modified: Aug 25, 2025
     Notes (Muzhi): 
        1. Fix joint limits for arm and gripper
    
     Last modified: Aug 25, 2025
     Notes (Zhiao): 
        1. Add textured glb based on beta1.0_v2_20250822_no_texture.urdf

     Last modified: Aug 22, 2025
     Notes (Muzhi): 
        1. Add textured glb based on beta1.0_v2_20250822_no_texture.urdf
-->
<robot
  name="hillbot_beta1.0_v2">
  <link name="root">
    <inertial>
      <mass value="1000.0" />
      <inertia ixx="40.0" ixy="0.0" ixz="0.0" iyy="40.0" iyz="0.0" izz="20.0" />
    </inertial>
  </link>
  <link name="root_1">
    <inertial>
      <mass value="1000.0" />
      <inertia ixx="40.0" ixy="0.0" ixz="0.0" iyy="40.0" iyz="0.0" izz="20.0" />
    </inertial>
  </link>
  <link name="root_2">
    <inertial>
      <mass value="1000.0" />
      <inertia ixx="40.0" ixy="0.0" ixz="0.0" iyy="40.0" iyz="0.0" izz="20.0" />
    </inertial>
  </link>
  <joint name="joint_root_x" type="prismatic">
    <parent link="root" />
    <child link="root_1" />
    <axis xyz="1 0 0" />
    <limit effort="4." lower="-20" upper="20" velocity="0.50" />
    <dynamics K="7000" damping="10." friction="10" />
  </joint>
  <joint name="joint_root_y" type="prismatic">
    <parent link="root_1" />
    <child link="root_2" />
    <axis xyz="0 1 0" />
    <limit effort="4." lower="-20" upper="20" velocity="0.50" />
    <dynamics K="7000" damping="10." friction="10" />
  </joint>
  <joint name="joint_root_z" type="revolute">
    <parent link="root_2" />
    <child link="base_link" />
    <axis xyz="0 0 1" />
    <limit effort="1.0" lower="-314.15" upper="314.15" velocity="0.50" />
    <!-- avoid the simulation
    bug of wrapping from upper limit of rotation to lower limit of rotation -->
    <dynamics K="7000" damping="10." friction="10" />
  </joint>

